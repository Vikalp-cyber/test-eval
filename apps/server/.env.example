# Copy to apps/server/.env (or set the same keys in repo-root .env).
# Repo-root `.env` loads first; `apps/server/.env` overrides on duplicate keys.

# Docker default (from docker-compose.yml postgres service).
DATABASE_URL=postgres://postgres:postgres@localhost:55432/healosbench

# Must be at least 32 characters (better-auth).
BETTER_AUTH_SECRET=development-only-change-this-to-a-long-random-string

# Base URL of this API (Bun/Hono), including port.
BETTER_AUTH_URL=http://localhost:3000

# Origin of the Next.js app (must match the URL you open in the browser).
CORS_ORIGIN=http://localhost:3101

ANTHROPIC_API_KEY=
